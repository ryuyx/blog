---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { useTranslations } from "@/i18n";
import { projectRepos } from "@/data/projects";
import config from "@/config";

interface RepoInfo {
  name: string;
  description: string | null;
  html_url: string;
  language: string | null;
  stargazers_count: number;
  homepage: string | null;
}

async function fetchRepo(owner: string, repo: string): Promise<RepoInfo | null> {
  try {
    const res = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
      headers: { Accept: "application/vnd.github+json" },
    });
    if (!res.ok) return null;
    return (await res.json()) as RepoInfo;
  } catch {
    return null;
  }
}

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const projects = await Promise.all(
  projectRepos.map(async (p) => {
    const gh = await fetchRepo(p.owner, p.repo);
    return {
      name: gh?.name ?? p.repo,
      description: gh?.description ?? p.fallback ?? "",
      url: gh?.html_url ?? `https://github.com/${p.owner}/${p.repo}`,
      language: gh?.language ?? undefined,
      stars: gh?.stargazers_count ?? undefined,
    };
  })
);
---

<Layout
  title={`${t.pages.projectsTitle} | ${config.site.title}`}
  description={t.pages.projectsDesc}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.projectsTitle} pageDesc={t.pages.projectsDesc}>
    <ul class="grid gap-4 sm:grid-cols-2">
      {
        projects.map((project) => (
          <li>
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border hover:border-accent block rounded-lg border p-5 transition-colors"
            >
              <h2 class="text-lg font-semibold">{project.name}</h2>
              <p class="text-foreground/70 mt-1 text-sm">
                {project.description}
              </p>
              <div class="mt-3 flex items-center gap-3 text-xs">
                {
                  project.language && (
                    <span class="bg-accent/10 text-accent rounded-full px-2 py-0.5">
                      {project.language}
                    </span>
                  )
                }
                {
                  project.stars != null && (
                    <span class="opacity-60">{project.stars} stars</span>
                  )
                }
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
